{
  "manifest_version": 3,
  "name": "TabTTL",
  "version": "1.0.0",
  "description": "Auto-close tabs after a configurable TTL. Supports allowlist/blocklist modes, per-domain TTL, grace period, and tab recovery.",
  "minimum_chrome_version": "102",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "idle"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TabTTL"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
